<!DOCTYPE html>

<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Ronde Von Vlanderen 2026</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>

<style>
body {
  font-family: -apple-system, sans-serif;
  margin: 0;
  background: #0a0f1c;
  color: #e5e7eb;
}
.container { max-width: 950px; margin: auto; padding: 20px; }
.card {
  background: #111827;
  padding: 20px;
  border-radius: 20px;
  margin-bottom: 20px;
}
.grid { display: grid; grid-template-columns: repeat(3,1fr); gap:10px;}
.big { font-size: 22px; font-weight: bold; text-align:center;}
#map { height: 320px; border-radius: 12px;}
</style>

</head>

<body>
<div class="container">

<h1>Ronde Von Vlanderen 2026</h1>

<div class="card grid">
<div class="big">247,6 km<br>Distance</div>
<div class="big">1791 m<br>D+</div>
<div class="big">Sub 10h<br>Objectif</div>
</div>

<div class="card">
<h2>⏱️ Prédiction</h2>
<p>Estimation : 9h15 – 10h</p>
</div>

<div class="card">
<h2>⏳ Countdown</h2>
<p id="countdown"></p>
</div>

<div class="card">
<h2>🌦️ Météo</h2>
<p>Départ (Anvers) : <span id="antwerp"></span></p>
<p>Arrivée (Audenarde) : <span id="oudenaarde"></span></p>
</div>

<div class="card">
<h2>🗺️ Parcours</h2>
<div id="map"></div>
</div>

<div class="card">
<h2>🍫 Nutrition</h2>
<ul>
<li>0–3h : 60g glucides/h</li>
<li>3–6h : 70g/h</li>
<li>6h+ : 80g/h</li>
</ul>
</div>

<div class="card">
<h2>🧳 Checklist</h2>
<ul>
<li>2 bidons glucides</li>
<li>8 gels/barres</li>
<li>Coupe-vent</li>
<li>Kit réparation</li>
<li>Téléphone</li>
</ul>
</div>

</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// countdown
const date = new Date("2026-04-05");
const now = new Date();
document.getElementById("countdown").innerText =
Math.floor((date-now)/(1000*60*60*24))+" jours";

// météo
async function w(lat,lon,id){
let r=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
let d=await r.json();
document.getElementById(id).innerText =
d.current_weather.temperature+"°C, vent "+d.current_weather.windspeed+" km/h";
}
w(51.22,4.40,"antwerp");
w(50.85,3.60,"oudenaarde");

// map
const map=L.map('map').setView([50.85,3.6],9);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

// GPX
fetch('route.gpx')
.then(r=>r.text())
.then(txt=>{
let xml=new DOMParser().parseFromString(txt,"text/xml");
let pts=[...xml.getElementsByTagName("trkpt")].map(p=>[
parseFloat(p.getAttribute("lat")),
parseFloat(p.getAttribute("lon"))
]);
let line=L.polyline(pts).addTo(map);
map.fitBounds(line.getBounds());
});
</script>

</body>
</html>
